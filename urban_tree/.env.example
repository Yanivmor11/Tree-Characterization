# Local debug/profile (IO only): place as `urban_tree/.env` — loaded from disk, not bundled in the app.
# Release and profile builds on CI should use `--dart-define-from-file=secrets.json` (see secrets.json.example).
#
# scripts/supabase_backend_deploy.sh reads SUPABASE_URL from this file to get the project ref
# (subdomain before .supabase.co). Or set SUPABASE_PROJECT_REF in the shell before running the script.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Supabase CLI only (deploy / link / db push): Personal Access Token from
# https://supabase.com/dashboard/account/tokens — never commit a real value; never ship in the app.
# Optional alternative to `npx supabase@latest login`. If leaked, revoke the token immediately.
# SUPABASE_ACCESS_TOKEN=
SUPABASE_ANON_KEY=your_supabase_anon_key

# Server-side scripts only (e.g. `scripts/import_tel_aviv_trees.py`). Never ship in the mobile app.
SUPABASE_SERVICE_ROLE_KEY=

# Tel Aviv municipal tree CSV (copy link from the portal’s CSV resource).
TEL_AVIV_TREES_CSV_URL=
# Optional CKAN discovery for --discover-csv:
TEL_AVIV_CKAN_API_URL=https://data.tel-aviv.gov.il
TEL_AVIV_CKAN_PACKAGE=trees

# Optional: direct OpenAI on mobile/desktop when set. If empty, the app uses Edge Functions
# `openai-suggest` / `openai-tree-insights` (set secret OPENAI_API_KEY in Supabase Dashboard).
OPENAI_API_KEY=
